{
    "name": "xternalsoft/php-whois",
    "version": "1.0.2",
    "description": "PHP WHOIS provides parsed and raw whois lookup of domains and ASN routes. Based on io-developer/php-whois v4.1.10.",
    "keywords": [
        "php",
        "whois",
        "query",
        "tld",
        "domain",
        "lookup",
        "info",
        "asn",
        "routes",
        "parser",
        "црщшы"
    ],
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/xternalsoft/php-whois",
    "authors": [
        {
            "name": "Xternalsoft",
            "homepage": "https://github.com/xternalsoft"
        }
    ],
    "require" : {
        "php" : ">=8.2",
        "ext-curl": "*",
        "ext-mbstring": "*",
        "ext-json": "*",
        "symfony/polyfill-intl-idn": "^1.27"
    },
    "require-dev" : {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Xternalsoft\\": "src/Xternalsoft/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "": [ "tests/" ]
        }
    },
    "scripts": {
        "test": [
            "phpunit --bootstrap tests/bootstrap.php tests"
        ]
    }
}
